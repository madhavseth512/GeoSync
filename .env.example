# ─── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# ─── JWT ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string_minimum_32_characters
JWT_EXPIRY=24h

# ─── PostgreSQL ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geosync
DB_USER=geosync_user
DB_PASSWORD=replace_with_strong_password
DB_MAX_CONNECTIONS=10

# ─── Redis ──────────────────────────────────────────────
# Used for geofence enter/exit state (always), and optionally as the Socket.IO
# Pub/Sub adapter for scaling out.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Enable the Socket.IO Redis adapter ONLY when running multiple Node instances.
# With one instance there are no peers to fan out to, so the adapter would cost a
# Redis PUBLISH per broadcast for zero benefit (and burn a metered free tier).
USE_REDIS_ADAPTER=false

# ─── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_API_MAX=100
# Location ingest is high-frequency and keyed per USER (not per IP), since friends
# on the same mobile carrier can share a NAT address.
RATE_LIMIT_LOCATION_MAX=60
SOCKET_THROTTLE_INTERVAL_MS=4000
SOCKET_MAX_VIOLATIONS=10
